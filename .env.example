# Required for auth (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Database (local default uses SQLite at ./data/studio.db)
# DATABASE_URL=./data/studio.db
# DATABASE_URL=postgresql://user:pass@host/db   # Neon for production

# Email (optional locally — emails print to terminal)
# RESEND_API_KEY=re_...
# EMAIL_FROM=AI Story Studio <onboarding@yourdomain.com>

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

